# --- Django ---
DJANGO_SECRET_KEY=change-me                     # required in production
DEBUG=True                                      # never True in production
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database / Redis ---
DATABASE_URL=postgres://pickme:pickme@localhost:5432/pickme
REDIS_URL=redis://localhost:6379/0

# --- Celery ---
CELERY_TASK_ALWAYS_EAGER=False                  # True runs tasks inline (tests/dev)

# --- Carpool ---
SWAP_REQUEST_EXPIRY_HOURS=48                    # pending swaps auto-expire after this

# --- Clerk auth ---
# Issuer of your Clerk instance, e.g. https://your-app.clerk.accounts.dev
CLERK_ISSUER=
# Defaults to $CLERK_ISSUER/.well-known/jwks.json when CLERK_ISSUER is set
CLERK_JWKS_URL=
# Comma-separated origins allowed in the JWT azp claim (empty = skip check)
CLERK_AUTHORIZED_PARTIES=
# Signing secret for the Clerk webhook endpoint (starts with whsec_)
CLERK_WEBHOOK_SIGNING_SECRET=

# --- Maps / trip tracking ---
MAPS_BACKEND=fake                               # fake | google (Distance Matrix)
GOOGLE_MAPS_API_KEY=                            # required when MAPS_BACKEND=google
LOCATION_PING_RETENTION_DAYS=30                 # nightly cleanup deletes older pings
ETA_THROTTLE_SECONDS=30                         # min interval between ETA recalcs per trip

# --- Notifications / push ---
PUSH_BACKEND=fake                               # fake | expo (Expo push service)
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
DISMISSAL_REMINDER_OFFSET_MINUTES=30            # fire pickup reminders this long before dismissal
